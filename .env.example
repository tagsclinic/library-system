# Database (Supabase PostgreSQL + Prisma)
# Copy BOTH strings from Supabase Dashboard → Connect → ORMs → Prisma
# Replace [YOUR-PASSWORD] with your real database password (reset in Database settings if needed).
# If the password contains special characters (@, #, /, etc.), URL-encode them.

# Transaction pooler — use for app runtime (Vercel/serverless). Port 6543 + pgbouncer=true
DATABASE_URL="postgresql://postgres.mnayswozzddxtdhbhmvx:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — use for migrations/db push. Port 5432, user "postgres" (no project suffix)
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.mnayswozzddxtdhbhmvx.supabase.co:5432/postgres"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://mnayswozzddxtdhbhmvx.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
# Legacy anon JWT (optional fallback)
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email (Resend) — optional; leave blank for NOT_CONFIGURED
RESEND_API_KEY=""
RESEND_FROM_EMAIL="LibraryInventory <dmv@tagsclinic.com>"

# SMS (Twilio) — optional; leave blank for NOT_CONFIGURED
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# Or use API key auth instead of TWILIO_AUTH_TOKEN:
TWILIO_API_KEY_SID=""
TWILIO_API_KEY_SECRET=""
TWILIO_PHONE_NUMBER="+18169004121"
TWILIO_VOICE_PHONE_NUMBER="+18169004121"

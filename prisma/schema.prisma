generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SubscriptionPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum BookStatus {
  AVAILABLE
  CHECKED_OUT
  LOST
  DAMAGED
  ARCHIVED
}

enum BookCondition {
  NEW
  EXCELLENT
  GOOD
  FAIR
  POOR
  DAMAGED
  LOST
}

enum BorrowerStatus {
  ACTIVE
  WATCHLIST
  BLOCKED
}

enum LoanPeriodType {
  ONE_WEEK
  TWO_WEEKS
  ONE_MONTH
  TWO_MONTHS
  CUSTOM
}

enum LoanStatus {
  ACTIVE
  RETURNED
  OVERDUE
  LOST
  DAMAGED
}

enum NotificationType {
  DUE_SOON
  OVERDUE
  RENEWAL_APPROVED
  LOST_NOTICE
  DAMAGE_NOTICE
}

enum NotificationChannel {
  EMAIL
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  NOT_CONFIGURED
}

enum PaymentStatus {
  PENDING
  PAID
  WAIVED
}

enum UserRole {
  ADMIN
  LIBRARIAN
  VIEWER
}

enum PlatformRole {
  SUPER_ADMIN
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  CHECKOUT
  CHECKIN
  RENEWAL
  STATUS_CHANGE
  LOGIN
  LOGOUT
}

enum RiskLevel {
  NONE
  LOW
  MEDIUM
  HIGH
}

enum OrganizationType {
  PUBLIC_LIBRARY
  SCHOOL
  PRIVATE_SCHOOL
  CHURCH
  MOSQUE
  NONPROFIT
  COMMUNITY_CENTER
  OTHER
}

model Organization {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique
  organizationType OrganizationType @default(OTHER)
  logo             String?
  email            String?
  phone            String?
  address          String?
  subscriptionPlan SubscriptionPlan @default(STARTER)
  termsContent     String?          @db.Text
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  books                    Book[]
  borrowers                Borrower[]
  loans                    Loan[]
  renewals                 Renewal[]
  conditionHistory         ConditionHistory[]
  notificationLogs         NotificationLog[]
  notificationTemplates    NotificationTemplate[]
  auditLogs                AuditLog[]
  appSettings              AppSettings[]
  members                  OrganizationMember[]
  integration              OrganizationIntegration?

  @@index([slug])
}

model OrganizationIntegration {
  id                    String    @id @default(cuid())
  organizationId        String    @unique
  googleRefreshToken    String?   @db.Text
  googleAccessToken     String?   @db.Text
  googleTokenExpiry     DateTime?
  googleAccountEmail    String?
  googleDriveFolderId   String?
  googleDriveFolderName String?   @default("LibraryInventory")
  googleConnectedAt     DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model PlatformUser {
  id        String       @id @default(cuid())
  userId    String       @unique
  email     String
  role      PlatformRole @default(SUPER_ADMIN)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([email])
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  email          String
  fullName       String?
  role           UserRole @default(VIEWER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([email])
}

model Book {
  id               String        @id @default(cuid())
  organizationId   String
  title            String
  author           String
  category         String?
  isbn             String?
  barcodeValue     String
  qrCodeValue      String
  barcodeImage     String?
  qrCodeImage      String?
  coverImageUrl    String?
  replacementValue Decimal?      @db.Decimal(10, 2)
  status           BookStatus    @default(AVAILABLE)
  currentCondition BookCondition @default(GOOD)
  notes            String?
  publishedYear    Int?
  publisher        String?
  edition          String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  organization     Organization  @relation(fields: [organizationId], references: [id])
  loans            Loan[]
  conditionHistory ConditionHistory[]
  auditLogs        AuditLog[]

  @@unique([organizationId, barcodeValue])
  @@unique([organizationId, qrCodeValue])
  @@index([organizationId])
  @@index([status])
  @@index([isbn])
  @@index([title])
  @@index([author])
  @@index([category])
  @@index([deletedAt])
}

model Borrower {
  id             String         @id @default(cuid())
  organizationId String
  fullName       String
  phone          String
  email          String?
  address        String?
  notes          String?
  status         BorrowerStatus @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  loans        Loan[]
  auditLogs    AuditLog[]

  @@index([organizationId])
  @@index([status])
  @@index([phone])
  @@index([email])
  @@index([fullName])
  @@index([deletedAt])
}

model Loan {
  id                   String         @id @default(cuid())
  organizationId       String
  bookId               String
  borrowerId           String
  checkoutDate         DateTime       @default(now())
  dueDate              DateTime
  returnDate           DateTime?
  loanPeriodType       LoanPeriodType
  customDays           Int?
  checkoutCondition    BookCondition
  returnCondition      BookCondition?
  checkoutNotes        String?
  returnNotes          String?
  termsAccepted        Boolean        @default(false)
  termsAcceptedAt      DateTime?
  termsVersion         String?        @default("1.0")
  status               LoanStatus     @default(ACTIVE)
  repairCost           Decimal?       @db.Decimal(10, 2)
  amountOwed           Decimal?       @db.Decimal(10, 2)
  paymentStatus        PaymentStatus?
  checkedOutBy         String?
  checkedInBy          String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  deletedAt            DateTime?

  organization     Organization       @relation(fields: [organizationId], references: [id])
  book             Book               @relation(fields: [bookId], references: [id])
  borrower         Borrower           @relation(fields: [borrowerId], references: [id])
  renewals         Renewal[]
  notifications    NotificationLog[]
  conditionHistory ConditionHistory[]
  auditLogs        AuditLog[]

  @@index([organizationId])
  @@index([status])
  @@index([bookId])
  @@index([borrowerId])
  @@index([dueDate])
  @@index([checkoutDate])
  @@index([deletedAt])
}

model Renewal {
  id             String   @id @default(cuid())
  organizationId String
  loanId         String
  oldDueDate     DateTime
  newDueDate     DateTime
  reason         String?
  approvedBy     String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  loan         Loan         @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([loanId])
}

model ConditionHistory {
  id             String        @id @default(cuid())
  organizationId String
  bookId         String
  loanId         String?
  condition      BookCondition
  notes          String?
  recordedBy     String?
  recordedAt     DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  book         Book         @relation(fields: [bookId], references: [id], onDelete: Cascade)
  loan         Loan?        @relation(fields: [loanId], references: [id])

  @@index([organizationId])
  @@index([bookId])
}

model NotificationLog {
  id             String              @id @default(cuid())
  organizationId String
  loanId         String?
  type           NotificationType
  channel        NotificationChannel
  recipient      String
  subject        String?
  message        String              @db.Text
  status         NotificationStatus  @default(PENDING)
  errorMsg       String?
  retryCount     Int                 @default(0)
  sentAt         DateTime?
  createdAt      DateTime            @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  loan         Loan?        @relation(fields: [loanId], references: [id])

  @@index([organizationId])
  @@index([status])
  @@index([type])
  @@index([loanId])
}

model NotificationTemplate {
  id             String           @id @default(cuid())
  organizationId String
  type           NotificationType
  subject        String
  body           String           @db.Text
  updatedAt      DateTime         @updatedAt
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, type])
  @@index([organizationId])
}

model AuditLog {
  id             String      @id @default(cuid())
  organizationId String
  userId         String?
  userEmail      String?
  action         AuditAction
  entityType     String
  entityId       String?
  description    String
  previousData   Json?
  newData        Json?
  ipAddress      String?
  userAgent      String?
  bookId         String?
  borrowerId     String?
  loanId         String?
  createdAt      DateTime    @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  book         Book?        @relation(fields: [bookId], references: [id])
  borrower     Borrower?    @relation(fields: [borrowerId], references: [id])
  loan         Loan?        @relation(fields: [loanId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@index([bookId])
  @@index([borrowerId])
}

model AppSettings {
  id             String   @id @default(cuid())
  organizationId String
  key            String
  value          String   @db.Text
  description    String?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, key])
  @@index([organizationId])
}
